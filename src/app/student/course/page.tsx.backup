'use client'

import { useState, useEffect } from 'react'
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card'
import { Button } from '@/components/ui/button'
import { Badge } from '@/components/ui/badge'
import { Progress } from '@/components/ui/progress'
import { 
  BookOpen, 
  Video, 
  FileText, 
  CheckCircle, 
  Lock, 
  Clock,
  Download,
  PlayCircle,
  ChevronRight,
  Award,
  Loader2,
  ArrowLeft
} from 'lucide-react'
import Link from 'next/link'
import { useRouter } from 'next/navigation'

interface Module {
  id: string
  title: string
  description: string
  weekNumber: number
  duration: number // minutes
  isCompleted: boolean
  isLocked: boolean
  videoUrl?: string
  resources: Resource[]
  quizId?: string
}

interface Resource {
  id: string
  title: string
  type: 'pdf' | 'template' | 'checklist'
  url: string
  size: string
}

export default function StudentCoursePage() {
  const router = useRouter()
  const [modules, setModules] = useState<Module[]>([])
  const [selectedModule, setSelectedModule] = useState<Module | null>(null)
  const [loading, setLoading] = useState(true)
  const [videoProgress, setVideoProgress] = useState<Record<string, number>>({})

  // Mock data - in production, fetch from Firebase
  useEffect(() => {
    loadCourseContent()
  }, [])

  const loadCourseContent = async () => {
    setLoading(true)
    try {
      // Simulate API call
      const mockModules: Module[] = [
        {
          id: 'module-1',
          title: 'Einführung in AI Automatisierung',
          description: 'Grundlagen und erste Schritte mit KI-Tools',
          weekNumber: 1,
          duration: 45,
          isCompleted: true,
          isLocked: false,
          videoUrl: 'https://example.com/video1.mp4',
          resources: [
            { id: 'r1', title: 'AI Grundlagen PDF', type: 'pdf', url: '#', size: '2.5 MB' },
            { id: 'r2', title: 'Tool Liste', type: 'template', url: '#', size: '500 KB' }
          ],
          quizId: 'quiz-1'
        },
        {
          id: 'module-2',
          title: 'ChatGPT für Business',
          description: 'Produktivität steigern mit ChatGPT',
          weekNumber: 1,
          duration: 60,
          isCompleted: true,
          isLocked: false,
          videoUrl: 'https://example.com/video2.mp4',
          resources: [
            { id: 'r3', title: 'ChatGPT Prompts', type: 'template', url: '#', size: '1 MB' }
          ],
          quizId: 'quiz-2'
        },
        {
          id: 'module-3',
          title: 'Automatisierung mit Make.com',
          description: 'Workflows automatisieren ohne Code',
          weekNumber: 2,
          duration: 90,
          isCompleted: false,
          isLocked: false,
          videoUrl: 'https://example.com/video3.mp4',
          resources: [
            { id: 'r4', title: 'Make.com Templates', type: 'template', url: '#', size: '3 MB' }
          ]
        },
        {
          id: 'module-4',
          title: 'Zapier Integration',
          description: 'Verbinden Sie Ihre Tools',
          weekNumber: 2,
          duration: 75,
          isCompleted: false,
          isLocked: false,
          videoUrl: 'https://example.com/video4.mp4',
          resources: []
        },
        {
          id: 'module-5',
          title: 'AI Content Creation',
          description: 'Erstellen Sie Content mit KI',
          weekNumber: 3,
          duration: 60,
          isCompleted: false,
          isLocked: true,
          resources: []
        },
      ]

      setModules(mockModules)
      
      // Select first incomplete module or first module
      const firstIncomplete = mockModules.find(m => !m.isCompleted && !m.isLocked)
      setSelectedModule(firstIncomplete || mockModules[0])
    } catch (error) {
      console.error('Error loading course content:', error)
    } finally {
      setLoading(false)
    }
  }

  const handleModuleClick = (module: Module) => {
    if (!module.isLocked) {
      setSelectedModule(module)
    }
  }

  const markModuleComplete = async (moduleId: string) => {
    try {
      // Save progress to Firebase
      setModules(prev => prev.map(m => 
        m.id === moduleId ? { ...m, isCompleted: true } : m
      ))
      
      // Unlock next module if it exists
      const currentIndex = modules.findIndex(m => m.id === moduleId)
      if (currentIndex < modules.length - 1) {
        setModules(prev => prev.map((m, idx) => 
          idx === currentIndex + 1 ? { ...m, isLocked: false } : m
        ))
      }
    } catch (error) {
      console.error('Error marking complete:', error)
    }
  }

  const completedCount = modules.filter(m => m.isCompleted).length
  const totalCount = modules.length
  const progressPercent = (completedCount / totalCount) * 100

  if (loading) {
    return (
      <div className="flex items-center justify-center min-h-screen">
        <Loader2 className="h-8 w-8 animate-spin text-blue-600" />
      </div>
    )
  }

  return (
    <div className="space-y-6">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <Button variant="ghost" onClick={() => router.push('/student')} className="mb-2">
            <ArrowLeft className="h-4 w-4 mr-2" />
            Zurück zum Dashboard
          </Button>
          <h1 className="text-3xl font-bold">Kursinhalte</h1>
          <p className="text-gray-600 mt-1">
            AI Automatisierung für E-Commerce
          </p>
        </div>
        <div className="text-right">
          <div className="text-sm text-gray-600">Gesamtfortschritt</div>
          <div className="text-2xl font-bold text-blue-600">{Math.round(progressPercent)}%</div>
          <div className="text-sm text-gray-500">{completedCount} von {totalCount} Module</div>
        </div>
      </div>

      {/* Progress Bar */}
      <Card>
        <CardContent className="pt-6">
          <Progress value={progressPercent} className="h-3" />
        </CardContent>
      </Card>

      <div className="grid gap-6 lg:grid-cols-3">
        {/* Module List */}
        <div className="lg:col-span-1 space-y-4">
          <Card>
            <CardHeader>
              <CardTitle className="text-lg">Module</CardTitle>
              <CardDescription>Wählen Sie ein Modul aus</CardDescription>
            </CardHeader>
            <CardContent className="space-y-2">
              {modules.map((module, index) => (
                <button
                  key={module.id}
                  onClick={() => handleModuleClick(module)}
                  disabled={module.isLocked}
                  className={`
                    w-full text-left p-4 rounded-lg border-2 transition-all
                    ${selectedModule?.id === module.id 
                      ? 'border-blue-600 bg-blue-50' 
                      : 'border-gray-200 hover:border-blue-300'
                    }
                    ${module.isLocked ? 'opacity-50 cursor-not-allowed' : 'cursor-pointer'}
                  `}
                >
                  <div className="flex items-start justify-between mb-2">
                    <div className="flex items-start gap-3 flex-1">
                      <div className="bg-white rounded-full p-2 border-2 border-gray-200">
                        {module.isCompleted ? (
                          <CheckCircle className="h-4 w-4 text-green-600" />
                        ) : module.isLocked ? (
                          <Lock className="h-4 w-4 text-gray-400" />
                        ) : (
                          <PlayCircle className="h-4 w-4 text-blue-600" />
                        )}
                      </div>
                      <div className="flex-1">
                        <div className="flex items-center gap-2 mb-1">
                          <span className="text-xs font-semibold text-blue-600">
                            Woche {module.weekNumber}
                          </span>
                          {module.isCompleted && (
                            <Badge variant="outline" className="text-xs bg-green-50 text-green-700 border-green-200">
                              Abgeschlossen
                            </Badge>
                          )}
                        </div>
                        <p className="font-semibold text-sm">{module.title}</p>
                        <div className="flex items-center gap-2 mt-1 text-xs text-gray-500">
                          <Clock className="h-3 w-3" />
                          {module.duration} Min
                        </div>
                      </div>
                    </div>
                    <ChevronRight className="h-5 w-5 text-gray-400 flex-shrink-0" />
                  </div>
                </button>
              ))}
            </CardContent>
          </Card>
        </div>

        {/* Content Viewer */}
        <div className="lg:col-span-2 space-y-6">
          {selectedModule ? (
            <>
              {/* Module Header */}
              <Card>
                <CardHeader>
                  <div className="flex items-start justify-between">
                    <div className="flex-1">
                      <div className="flex items-center gap-2 mb-2">
                        <Badge variant="outline">Woche {selectedModule.weekNumber}</Badge>
                        {selectedModule.isCompleted && (
                          <Badge className="bg-green-600">
                            <CheckCircle className="h-3 w-3 mr-1" />
                            Abgeschlossen
                          </Badge>
                        )}
                      </div>
                      <CardTitle className="text-2xl">{selectedModule.title}</CardTitle>
                      <CardDescription className="mt-2">
                        {selectedModule.description}
                      </CardDescription>
                    </div>
                  </div>
                </CardHeader>
              </Card>

              {/* Video Player */}
              {selectedModule.videoUrl && (
                <Card>
                  <CardHeader>
                    <CardTitle className="flex items-center gap-2">
                      <Video className="h-5 w-5" />
                      Video Lektion
                    </CardTitle>
                  </CardHeader>
                  <CardContent>
                    <div className="aspect-video bg-gray-900 rounded-lg flex items-center justify-center">
                      <div className="text-center text-white">
                        <Video className="h-16 w-16 mx-auto mb-4 opacity-50" />
                        <p className="text-sm">Video Player wird hier eingebunden</p>
                        <p className="text-xs text-gray-400 mt-2">
                          Integration mit Vimeo/YouTube/Mux
                        </p>
                      </div>
                    </div>
                    
                    {!selectedModule.isCompleted && (
                      <div className="mt-4 flex justify-end">
                        <Button 
                          onClick={() => markModuleComplete(selectedModule.id)}
                          size="lg"
                        >
                          <CheckCircle className="h-4 w-4 mr-2" />
                          Als abgeschlossen markieren
                        </Button>
                      </div>
                    )}
                  </CardContent>
                </Card>
              )}

              {/* Quiz */}
              {selectedModule.quizId && (
                <Card>
                  <CardHeader>
                    <CardTitle className="flex items-center gap-2">
                      <Award className="h-5 w-5" />
                      Quiz
                    </CardTitle>
                    <CardDescription>
                      Testen Sie Ihr Wissen zu diesem Modul
                    </CardDescription>
                  </CardHeader>
                  <CardContent>
                    <Button asChild className="w-full" size="lg">
                      <Link href={`/student/quiz/${selectedModule.quizId}`}>
                        <Award className="h-4 w-4 mr-2" />
                        Quiz starten
                      </Link>
                    </Button>
                  </CardContent>
                </Card>
              )}

              {/* Resources */}
              {selectedModule.resources.length > 0 && (
                <Card>
                  <CardHeader>
                    <CardTitle className="flex items-center gap-2">
                      <FileText className="h-5 w-5" />
                      Materialien
                    </CardTitle>
                    <CardDescription>
                      Zusätzliche Ressourcen für dieses Modul
                    </CardDescription>
                  </CardHeader>
                  <CardContent>
                    <div className="space-y-2">
                      {selectedModule.resources.map(resource => (
                        <div
                          key={resource.id}
                          className="flex items-center justify-between p-3 border rounded-lg hover:bg-gray-50 transition-colors"
                        >
                          <div className="flex items-center gap-3">
                            <div className="bg-blue-100 rounded p-2">
                              <FileText className="h-5 w-5 text-blue-600" />
                            </div>
                            <div>
                              <p className="font-medium text-sm">{resource.title}</p>
                              <p className="text-xs text-gray-500">
                                {resource.type.toUpperCase()} • {resource.size}
                              </p>
                            </div>
                          </div>
                          <Button variant="ghost" size="sm" asChild>
                            <a href={resource.url} download>
                              <Download className="h-4 w-4" />
                            </a>
                          </Button>
                        </div>
                      ))}
                    </div>
                  </CardContent>
                </Card>
              )}

              {/* Navigation */}
              <Card>
                <CardContent className="pt-6">
                  <div className="flex items-center justify-between">
                    <Button
                      variant="outline"
                      onClick={() => {
                        const currentIndex = modules.findIndex(m => m.id === selectedModule.id)
                        if (currentIndex > 0) {
                          setSelectedModule(modules[currentIndex - 1])
                        }
                      }}
                      disabled={modules.findIndex(m => m.id === selectedModule.id) === 0}
                    >
                      <ArrowLeft className="h-4 w-4 mr-2" />
                      Vorheriges Modul
                    </Button>
                    
                    <Button
                      onClick={() => {
                        const currentIndex = modules.findIndex(m => m.id === selectedModule.id)
                        if (currentIndex < modules.length - 1) {
                          const nextModule = modules[currentIndex + 1]
                          if (!nextModule.isLocked) {
                            setSelectedModule(nextModule)
                          }
                        }
                      }}
                      disabled={
                        modules.findIndex(m => m.id === selectedModule.id) === modules.length - 1 ||
                        modules[modules.findIndex(m => m.id === selectedModule.id) + 1]?.isLocked
                      }
                    >
                      Nächstes Modul
                      <ChevronRight className="h-4 w-4 ml-2" />
                    </Button>
                  </div>
                </CardContent>
              </Card>
            </>
          ) : (
            <Card>
              <CardContent className="pt-12 pb-12 text-center">
                <BookOpen className="h-16 w-16 mx-auto mb-4 text-gray-400" />
                <p className="text-gray-600">Wählen Sie ein Modul aus der Liste</p>
              </CardContent>
            </Card>
          )}
        </div>
      </div>
    </div>
  )
}
