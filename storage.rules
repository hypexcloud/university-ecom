rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Course content (videos, PDFs, etc.)
    match /courses/{courseId}/{allPaths=**} {
      // Only enrolled users can read course content
      allow read: if request.auth != null &&
                  hasActiveEnrollment(courseId);
      // Only admins can upload course content
      allow write: if request.auth != null &&
                   isAdmin();
    }

    // User uploads (profile pictures, assignments, etc.)
    match /users/{userId}/{allPaths=**} {
      // Users can read and write their own files
      allow read, write: if request.auth != null &&
                         request.auth.uid == userId;
      // Admins can read all user files
      allow read: if request.auth != null &&
                  isAdmin();
    }

    // Support ticket attachments
    match /support/{ticketId}/{allPaths=**} {
      // Users can upload to their own tickets
      allow write: if request.auth != null &&
                   isTicketOwner(ticketId);
      // Users and staff can read ticket attachments
      allow read: if request.auth != null &&
                  (isTicketOwner(ticketId) || isStaff());
    }

    // Public assets (company logos, general images)
    match /public/{allPaths=**} {
      // Anyone can read public files
      allow read: if true;
      // Only admins can upload public files
      allow write: if request.auth != null &&
                   isAdmin();
    }

    // Helper functions
    function isAdmin() {
      return request.auth != null &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isStaff() {
      return request.auth != null &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'instructor'];
    }

    function hasActiveEnrollment(courseId) {
      return request.auth != null &&
             firestore.exists(/databases/(default)/documents/enrollments/$(request.auth.uid + '_' + courseId)) &&
             firestore.get(/databases/(default)/documents/enrollments/$(request.auth.uid + '_' + courseId)).data.status == 'active';
    }

    function isTicketOwner(ticketId) {
      return request.auth != null &&
             firestore.get(/databases/(default)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
