rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isInstructor() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'instructor'];
    }
    
    function hasActiveEnrollment(courseType) {
      return exists(/databases/$(database)/documents/enrollments/$(request.auth.uid + '_' + courseType)) &&
             get(/databases/$(database)/documents/enrollments/$(request.auth.uid + '_' + courseType)).data.status == 'active';
    }

    // Users collection
    match /users/{userId} {
      // Users can read and write their own data
      allow read, write: if isOwner(userId);
      // Admins can read all users
      allow read: if isAdmin();
      // Admins can update user roles and status
      allow update: if isAdmin();
    }

    // Courses collection
    match /courses/{courseId} {
      // Anyone can read active courses (for marketing pages)
      allow read: if resource.data.isActive == true;
      // Only admins can create, update, or delete courses
      allow write: if isAdmin();
    }

    // Enrollments collection
    match /enrollments/{enrollmentId} {
      // Users can read their own enrollments
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Users can update their own progress (but not other fields)
      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['progress', 'updatedAt']);
      // Only admins can create enrollments (after payment)
      allow create: if isAdmin();
      // Admins can read and update all enrollments
      allow read, update: if isAdmin();
    }

    // Support tickets collection
    match /support_tickets/{ticketId} {
      // Users can create tickets
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Users can read their own tickets
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Users can add messages to their own tickets
      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messages', 'updatedAt']);
      // Admins and instructors can read and update all tickets
      allow read, update: if isInstructor();
    }

    // Community access collection
    match /community_access/{userId} {
      // Users can read their own community access
      allow read: if isOwner(userId);
      // Only admins can create and update community access
      allow write: if isAdmin();
    }

    // Payments collection
    match /payments/{paymentId} {
      // Users can read their own payments
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Only admins can create and update payments
      allow write: if isAdmin();
    }

    // Intake responses collection
    match /intake_responses/{intakeId} {
      // Anyone can create intake responses (for pre-purchase)
      allow create: if true;
      // Users can read their own intake responses
      allow read: if isAuthenticated() && resource.data.email == request.auth.token.email;
      // Only admins can read all and update intake responses
      allow read, update: if isAdmin();
    }

    // User activity collection
    match /user_activity/{activityId} {
      // Users can create their own activity logs
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Users can read their own activity
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Admins can read all activity
      allow read: if isAdmin();
    }

    // Admin settings collection
    match /admin_settings/{settingId} {
      // Anyone can read public settings (for course availability, etc.)
      allow read: if true;
      // Only admins can update settings
      allow write: if isAdmin();
    }

    // Email templates collection
    match /email_templates/{templateId} {
      // Only admins can manage email templates
      allow read, write: if isAdmin();
    }

    // Email logs collection
    match /email_logs/{logId} {
      // Users can read their own email logs
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Only admins can create and read all email logs
      allow create: if isAdmin();
      allow read: if isAdmin();
    }

    // Subcollections for nested data

    // Course modules (subcollection of courses)
    match /courses/{courseId}/modules/{moduleId} {
      // Enrolled users can read modules for their courses
      allow read: if isAuthenticated() && hasActiveEnrollment(get(/databases/$(database)/documents/courses/$(courseId)).data.type);
      // Only admins can manage modules
      allow write: if isAdmin();
    }

    // Support ticket messages (subcollection of support_tickets)
    match /support_tickets/{ticketId}/messages/{messageId} {
      // Users can read messages from their own tickets
      allow read: if isAuthenticated() && 
                  get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid;
      // Users can create messages in their own tickets
      allow create: if isAuthenticated() && 
                    get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid &&
                    request.resource.data.senderId == request.auth.uid;
      // Admins and instructors can read and create messages in any ticket
      allow read, create: if isInstructor();
    }

    // Default deny rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
