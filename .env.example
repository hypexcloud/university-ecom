# University Ecom Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres

# Email Configuration (Resend) - NEW
RESEND_API_KEY=re_your_resend_api_key_here

# Email Settings - Choose ONE option below:

# OPTION 1: Vercel Subdomain (Free, works immediately) - NEW
EMAIL_FROM_EMAIL="noreply@university-ecom.vercel.app"
EMAIL_REPLY_TO="support@university-ecom.vercel.app"
EMAIL_SUPPORT_EMAIL="support@university-ecom.vercel.app"

# OPTION 2: Custom Domain (Professional, requires domain setup) - NEW
# EMAIL_FROM_EMAIL="noreply@university-ecom.com"
# EMAIL_REPLY_TO="support@university-ecom.com"
# EMAIL_SUPPORT_EMAIL="support@university-ecom.com"

# Common Email Settings - NEW
EMAIL_FROM_NAME="University Ecom"

# Email Features (Optional - all default to true) - NEW
EMAIL_ENABLE_AUTOMATION=true
EMAIL_ENABLE_LOGGING=true
EMAIL_ENABLE_TRACKING=true

# Development Settings
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Deployment - NEW
# When deploying to Vercel, your domain will be auto-detected
# Just make sure to set these environment variables in your Vercel dashboard

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Crypto Wallets (for manual crypto payments)
CRYPTO_WALLET_BTC=
CRYPTO_WALLET_ETH=
CRYPTO_WALLET_USDT_ERC20=
CRYPTO_WALLET_USDT_TRC20=

# Bunny Stream (video hosting)
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_PULL_ZONE=
BUNNY_STREAM_SIGNING_KEY=

# Crisp Livechat
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Upstash Rate Limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Affiliate
AFFILIATE_COOKIE_DAYS=30

# Sentry Error Tracking
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
