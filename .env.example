# University Ecom - Environment Variables

# App Configuration
NEXT_PUBLIC_APP_NAME="University Ecom"
NEXT_PUBLIC_APP_URL="https://university-ecom.com"
NEXT_PUBLIC_APP_DESCRIPTION="Professionelle AI & Dropshipping Kurse für Unternehmer in Europa"

# Firebase Configuration (Client-side - REQUIRED)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Admin SDK (Server-side - REQUIRED for backend operations)
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""

# Payment Providers
# Stripe (REQUIRED for payment processing)
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayPal (REQUIRED for PayPal payments)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""

# Coinbase Commerce (REQUIRED for crypto payments)
COINBASE_COMMERCE_API_KEY=""
COINBASE_COMMERCE_WEBHOOK_SECRET=""

# Video Streaming (Mux - REQUIRED for course videos)
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""
MUX_ENCRYPTION_KEY=""

# Email Service (SendGrid - REQUIRED for email automation)
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@university-ecom.com"
SUPPORT_EMAIL="support@university-ecom.com"

# Calendar Integration (Cal.com - REQUIRED for support scheduling)
CAL_COM_API_KEY=""
CAL_COM_EVENT_TYPE_ID=""

# Analytics (Plausible - OPTIONAL but recommended)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# Security & Rate Limiting
NEXTAUTH_SECRET=""
NEXTAUTH_URL=""

# Database Encryption
DATABASE_ENCRYPTION_KEY=""

# Development & Testing
NODE_ENV="development"
ENABLE_SEED_DATA="true"
ENABLE_DEBUG_LOGS="true"

# Community Integration
WHATSAPP_API_TOKEN=""
DISCORD_BOT_TOKEN=""
DISCORD_SERVER_ID=""

# File Upload (Cloudinary or similar)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Monitoring & Error Tracking (Sentry)
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Redis for Session Storage (optional)
REDIS_URL=""

# Webhook URLs for external integrations
WEBHOOK_BASE_URL="https://university-ecom.com/api/webhooks"

# Feature Flags
FEATURE_AI_COURSE="true"
FEATURE_DROPSHIPPING_COURSE="true"
FEATURE_COMMUNITY_ACCESS="true"
FEATURE_MENTORING="true"
FEATURE_CRYPTO_PAYMENTS="true"

# Admin Configuration
ADMIN_EMAIL="admin@university-ecom.com"
SUPER_ADMIN_EMAILS="admin@university-ecom.com,founder@university-ecom.com"

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="900000"

# CORS Configuration
ALLOWED_ORIGINS="https://university-ecom.com,https://www.university-ecom.com"

# Content Delivery
CDN_URL=""
ASSETS_URL=""

# Backup & Recovery
BACKUP_BUCKET=""
BACKUP_FREQUENCY="daily"

# Compliance
COOKIE_CONSENT_ENABLED="true"
GDPR_COMPLIANCE_MODE="true"
DATA_RETENTION_DAYS="2555" # 7 years for financial records

# A/B Testing
FEATURE_AB_TESTING="false"
AB_TESTING_PROVIDER=""

# Customer Support
SUPPORT_CHAT_ENABLED="false"
SUPPORT_PHONE="+49 (0) 30 12345678"
SUPPORT_HOURS="09:00-17:00 CET"

# Marketing Automation
MARKETING_AUTOMATION_ENABLED="true"
DRIP_CAMPAIGN_DELAY_DAYS="7"

# Course Content
DEFAULT_COURSE_LANGUAGE="de"
SUPPORTED_LANGUAGES="de,en"
COURSE_VIDEO_QUALITY="1080p"

# Business Logic
DEFAULT_TIMEZONE="Europe/Berlin"
DEFAULT_CURRENCY="EUR"
VAT_RATE="0.19"
REFUND_PERIOD_DAYS="14"

# Development Utilities
SEED_ADMIN_USER="true"
MOCK_PAYMENT_SUCCESS="false"
BYPASS_EMAIL_VERIFICATION="false"
